# Required — generate a long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_long_random_string

# Required — must match the HMAC_SECRET value on Railway
HMAC_SECRET=change_me_to_a_long_random_string

# Required if your events use KDF-based NFC signing (useKdf=true) — copy from Railway
HMAC_MASTER_KEY=

# Optional — enables the demo login panel (copy from Railway if needed)
DEMO_SECRET=

# Optional but recommended — enables full event data sync from Railway
# Format: postgres://user:password@host:port/database
RAILWAY_SYNC_URL=

# Optional — human-readable name shown in the admin-web Local Servers panel
# Defaults to the machine hostname if not set
LOCAL_SERVER_NAME=
