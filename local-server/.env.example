# Required
SESSION_SECRET=change_me_to_a_long_random_string
HMAC_SECRET=change_me_to_a_long_random_string

# Optional: enables demo login panel in the app
DEMO_SECRET=

# Optional: syncs bracelet balances from Railway DB every 2 minutes
# Get this from Railway → your project → PostgreSQL → Connect
RAILWAY_SYNC_URL=
