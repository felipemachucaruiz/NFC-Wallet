{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/admin-web run build"
  },
  "deploy": {
    "startCommand": "npx serve -s artifacts/admin-web/dist -l $PORT --single",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
