{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "artifacts/admin-web/Dockerfile"
  },
  "deploy": {
    "startCommand": "node artifacts/admin-web/server/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
