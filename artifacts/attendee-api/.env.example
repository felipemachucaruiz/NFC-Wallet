# =============================================================================
# Attendee API — Environment Variables
# =============================================================================
# Copy this file to .env (never commit .env) and fill in the values below.
# All variables marked [REQUIRED] must be set; [OPTIONAL] variables have safe
# defaults and can be omitted unless you need to override them.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# [REQUIRED] PostgreSQL connection string.
# On Railway, this is automatically injected when you add the PostgreSQL plugin
# and link it to this service.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# [REQUIRED] Port the HTTP server listens on.
# Railway sets this automatically; you only need to set it in local dev.
PORT=3002

# [OPTIONAL] Node environment. Set to "production" on Railway.
NODE_ENV=production

# [OPTIONAL] Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# [OPTIONAL] Set to "true" when running behind a trusted reverse proxy (Railway,
# Nginx, etc.) so that Express reads X-Forwarded-For headers for real client IPs
# and the rate limiter works correctly.
# Railway always terminates TLS and forwards headers — set this to "true".
TRUSTED_PROXY=true

# -----------------------------------------------------------------------------
# OIDC / Authentication
# -----------------------------------------------------------------------------

# [REQUIRED for auth] The OIDC client ID registered with your identity provider.
# On Replit this is the REPL_ID (set automatically). On Railway or any other
# deployment, set CLIENT_ID to the client ID issued by your OIDC provider.
# CLIENT_ID takes precedence over REPL_ID if both are present.
CLIENT_ID=your-oidc-client-id

# [OPTIONAL] OIDC issuer URL. Defaults to "https://replit.com/oidc".
# Override this when using a different identity provider on Railway.
# OIDC_ISSUER_URL takes precedence over the legacy ISSUER_URL variable.
OIDC_ISSUER_URL=https://replit.com/oidc

# [OPTIONAL] Legacy alias for OIDC_ISSUER_URL. Prefer OIDC_ISSUER_URL for new
# deployments. Kept for backward compatibility with existing Replit deployments.
# ISSUER_URL=https://replit.com/oidc

# [OPTIONAL — Replit only] Set automatically inside a Replit Repl. Use CLIENT_ID
# instead when deploying outside of Replit.
# REPL_ID=your-repl-id

# -----------------------------------------------------------------------------
# Wompi Payment Gateway
# -----------------------------------------------------------------------------
# Wompi is the payment processor used for self-service top-ups (Colombia).
# See https://docs.wompi.co for account setup.

# [OPTIONAL] Wompi API base URL.
# Defaults to the sandbox URL. Set to "https://production.wompi.co/v1" for live payments.
WOMPI_BASE_URL=https://sandbox.wompi.co/v1

# [OPTIONAL] Wompi public key (shown in your Wompi dashboard).
WOMPI_PUBLIC_KEY=pub_test_...

# [OPTIONAL] Wompi private key (shown in your Wompi dashboard).
WOMPI_PRIVATE_KEY=prv_test_...

# [OPTIONAL] Wompi webhook events secret (used to verify webhook signatures).
WOMPI_EVENTS_SECRET=...

# [OPTIONAL] Base URL of your attendee-facing web app. Used to build Wompi
# redirect URLs after payment completion.
APP_URL=https://your-railway-service.up.railway.app

# -----------------------------------------------------------------------------
# Attestation (Device Integrity)
# -----------------------------------------------------------------------------

# [OPTIONAL] Google Play Integrity API project number.
# Only required if Android device attestation is enabled.
PLAY_INTEGRITY_PROJECT_ID=123456789

# [OPTIONAL] Apple DeviceCheck team ID and bundle ID.
# Only required if iOS device attestation is enabled.
APPLE_TEAM_ID=ABCDE12345
APPLE_BUNDLE_ID=com.example.myapp

# [OPTIONAL] Development bypass secret for attestation checks.
# When set in non-production environments, requests with the header
# X-Attestation-Dev-Secret: <value> skip real attestation validation.
# NEVER set this in production.
ATTESTATION_DEV_SECRET=
