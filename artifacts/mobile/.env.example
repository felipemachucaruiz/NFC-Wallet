# =============================================================================
# Tapee Mobile App — Environment Variables
# =============================================================================
# Copy this file to .env (never commit .env) and fill in the values below.
#
# IMPORTANT — Metro bundle-time variables:
# All EXPO_PUBLIC_* variables are evaluated at build/bundle time by Metro.
# They are baked into the JavaScript bundle when you run `expo export` or
# `expo start`. Setting or changing them after the bundle is produced has
# NO effect. You MUST set them to the correct values before running:
#
#   EXPO_PUBLIC_DOMAIN=your-api.up.railway.app \
#   EXPO_PUBLIC_ATTENDEE_DOMAIN=your-attendee-api.up.railway.app \
#   npx expo export --platform web
#
# =============================================================================

# [REQUIRED] Domain (host only, no https://) of the API Server service.
# This is the Railway public domain for the api-server service.
# Example: my-api-server-production.up.railway.app
EXPO_PUBLIC_DOMAIN=your-api-server.up.railway.app

# [OPTIONAL] Domain (host only, no https://) of the Attendee API service.
# When set, attendee-specific calls (balance, top-ups, self-service) are
# directed to this separate service instead of the main API Server.
# If omitted, all requests fall back to EXPO_PUBLIC_DOMAIN.
# Example: my-attendee-api-production.up.railway.app
EXPO_PUBLIC_ATTENDEE_DOMAIN=your-attendee-api.up.railway.app
