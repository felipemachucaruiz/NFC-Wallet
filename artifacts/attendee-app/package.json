{
  "name": "@workspace/attendee-app",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "CI=1 EXPO_PACKAGER_PROXY_URL=https://$REPLIT_EXPO_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_REPL_ID=$REPL_ID REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN pnpm exec expo start --localhost --port $PORT",
    "build": "node scripts/build.js",
    "serve": "node server/serve.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:apk": "EXPO_TOKEN=$EXPO_TOKEN eas build -p android --profile preview --non-interactive",
    "build:dev-apk": "EXPO_TOKEN=$EXPO_TOKEN eas build -p android --profile development --non-interactive",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo/cli": "54.0.23",
    "@expo/config-plugins": "~54.0.4",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "catalog:",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.27",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.11",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-router": "~6.0.17",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "^1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "typescript": "~5.9.2",
    "zod": "catalog:"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-nfc-manager"
        ]
      }
    }
  },
  "dependencies": {
    "@sentry/react-native": "^7.2.0",
    "@tanstack/query-async-storage-persister": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.21",
    "expo-apple-authentication": "^55.0.13",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "^55.0.20",
    "expo-localization": "^17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "^0.32.16",
    "expo-secure-store": "^15.0.8",
    "expo-sharing": "^55.0.19",
    "expo-updates": "^29.0.16",
    "i18next": "^25.10.9",
    "react-i18next": "^16.6.5",
    "nfc-hce": "file:./modules/nfc-hce",
    "react-native-nfc-manager": "^3.17.2",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-webview": "^13.16.1",
    "react-native-worklets": "0.5.1"
  }
}
